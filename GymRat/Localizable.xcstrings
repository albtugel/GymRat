        }
      }
    },
    "ai_greeting" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hallo! Ich helfe dir bei der Analyse. Wie viele Stunden hast du heute geschlafen?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hi! I can help with analysis. How many hours did you sleep today?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Привет! Я помогу с анализом. Сколько часов ты спал сегодня?"
          }
        }
      }
    },
